{
  "cleanupPeriodDays": 60,
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Glob",
      "Grep",
      "LS",
      "mcp__context7",
      "mcp__crome-devtools",
      "mcp__gemini-cli",
      "mcp__aws-cdk-mcp-server",
      "mcp__aws-documentation-mcp-server"
    ],
    "deny": [
      "Bash(aws s3 rm:*)",
      "Bash(aws s3 rb:*)",
      "Bash(aws ec2 terminate-instances:*)",
      "Bash(aws rds delete-db-instance:*)",
      "Bash(aws rds delete-db-cluster:*)",
      "Bash(aws lambda delete-function:*)",
      "Bash(aws iam delete-:*)",
      "Bash(aws cloudformation delete-stack:*)",
      "Bash(aws dynamodb delete-table:*)",
      "Bash(aws sns delete-topic:*)",
      "Bash(aws sqs delete-queue:*)",
      "Bash(curl:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh variable delete:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(wget:*)",
      "Read(.env.*)",
      "Read(.env)",
      "Read(.envrc)",
      "Read(~/.aws/**)",
      "Read(**/*key*)",
      "Read(**/.ssh/**)",
      "Read(env.json)",
      "Read(id_rsa)",
      "Read(id_dsa)",
      "Edit(.env*)",
      "Edit(.env)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Write(.env*)",
      "Write(.env)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)"
    ],
    "ask": [
      "Bash(aws ec2 run-instances:*)",
      "Bash(aws ec2 start-instances:*)",
      "Bash(aws ec2 stop-instances:*)",
      "Bash(aws cloudformation create-stack:*)",
      "Bash(aws cloudformation update-stack:*)",
      "Bash(aws lambda create-function:*)",
      "Bash(aws lambda update-function-code:*)",
      "Bash(aws s3 cp:*)",
      "Bash(aws s3 sync:*)",
      "Bash(aws s3 mv:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git commit:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue create:*)",
      "Bash(gh release create:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "skill-creator@awesome-claude-skills": true,
    "frontend-design@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "language": "日本語",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "plansDirectory": "./plans"
}
